{
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash(* --version)",
      "Bash(* --help *)",

      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",

      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",

      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(date:*)",
      "Bash(du:*)",
      "Bash(df:*)",

      "Bash(uv run:*)",
      "Bash(uv pip list:*)",
      "Bash(uv pip show:*)",
      "Bash(uv tree:*)",
      "Bash(uv version:*)",

      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew search:*)",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git remote -v:*)",
      "Bash(git config --get:*)",
      "Bash(git shortlog:*)",
      "Bash(git tag -l:*)",
      "Bash(git fetch:*)",

      "Bash(ghq root:*)",
      "Bash(ghq list:*)",

      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue status:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh search:*)",

      "Bash(glab mr list:*)",
      "Bash(glab mr view:*)",
      "Bash(glab mr status:*)",
      "Bash(glab mr checks:*)",
      "Bash(glab mr diff:*)",
      "Bash(glab issue list:*)",
      "Bash(glab issue view:*)",
      "Bash(glab issue status:*)",
      "Bash(glab ci list:*)",
      "Bash(glab ci view:*)",
      "Bash(glab ci status:*)",
      "Bash(glab repo view:*)",
      "Bash(glab repo list:*)",
      "Bash(glab release list:*)",
      "Bash(glab release view:*)"
    ],
    "deny": [
      "Bash(python:*)",
      "Bash(python3:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify-waiting.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify-complete.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun x ccusage statusline"
  },
  "alwaysThinkingEnabled": true
}
